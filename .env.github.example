# GitHub Personal Access Token (PAT)
# Recommended: create a NEW token and do NOT paste it into chat logs.
# Needed scopes: classic PAT -> "repo" (or fine-grained with repo create/push permissions).
GITHUB_TOKEN=your_token_here

# Optional overrides
# GITHUB_OWNER=your_github_username
# GITHUB_REPO=cpa-authfiles-cli
# GITHUB_DESCRIPTION=CLI tool to manage CLIProxyAPI /v0/management/auth-files
# GITHUB_PUBLIC=true
